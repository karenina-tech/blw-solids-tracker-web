{
  "name": "blw-solids-tracker-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "types": "tsc --noEmit && echo ✨ Types are correct",
    "typecheck:watch": "tsc --noEmit --watch",
    "verify": "npm audit --audit-level=high && tsc --noEmit && jest --config jest.config.cjs && tsc && vite build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.9",
    "ts-jest": "^29.2.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.1"
  }
}
